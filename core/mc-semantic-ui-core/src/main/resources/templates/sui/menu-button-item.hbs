{{!--
  One UiMenuButton popover entry, rendered recursively. Mirror of
  renderMenuButtonItem() in renderers/menu-button.ts. A divider, a nesting group
  (a submenu — same UiMenuItem.children the sidebar uses, self-recursing via this
  partial), or a leaf (button dispatches, anchor navigates).
--}}
{{#if divider}}<div class="sui-menu-button-sep"{{{events this "click"}}} role="separator"></div>{{else}}{{#if children}}<div class="sui-menu-button-group" id="{{id}}" data-id="{{id}}"><button type="button" class="sui-menu-button-item sui-menu-button-item--group{{#if danger}} is-danger{{/if}}" role="menuitem" aria-haspopup="menu" aria-expanded="false"><span class="sui-menu-button-item-icon">{{#if icon}}{{{icon icon}}}{{/if}}</span><span class="sui-menu-button-item-label">{{label}}</span>{{#if badge}}<span class="sui-menu-button-item-badge">{{badge}}</span>{{/if}}<span class="sui-menu-button-submenu-caret">{{{icon "chevron-right"}}}</span></button><div class="sui-menu-button-submenu" role="menu">{{#each children}}{{> menu-button-item}}{{/each}}</div></div>{{else}}{{#if onClick}}<button type="button" class="sui-menu-button-item{{#if danger}} is-danger{{/if}}" id="{{id}}" data-id="{{id}}" role="menuitem" data-trigger='{{{trigger onClick}}}'{{#if confirm}} data-confirm="{{confirm}}"{{/if}}><span class="sui-menu-button-item-icon">{{#if icon}}{{{icon icon}}}{{/if}}</span><span class="sui-menu-button-item-label">{{label}}</span>{{#if badge}}<span class="sui-menu-button-item-badge">{{badge}}</span>{{/if}}</button>{{else}}<a class="sui-menu-button-item{{#if danger}} is-danger{{/if}}" id="{{id}}" data-id="{{id}}" role="menuitem" href="{{#if href}}{{href}}{{else}}#{{/if}}" data-href="{{#if href}}{{href}}{{else}}#{{/if}}"><span class="sui-menu-button-item-icon">{{#if icon}}{{{icon icon}}}{{/if}}</span><span class="sui-menu-button-item-label">{{label}}</span>{{#if badge}}<span class="sui-menu-button-item-badge">{{badge}}</span>{{/if}}</a>{{/if}}{{/if}}{{/if}}
